{
  "name": "@readme-bot/action",
  "version": "0.1.0",
  "private": false,
  "license": "MIT",
  "description": "GitHub Action that suggests README updates on pull requests using your choice of LLM (OpenAI / Anthropic / Gemini).",
  "main": "dist/index.js",
  "scripts": {
    "build": "esbuild src/index.ts --bundle --platform=node --target=node20 --outfile=dist/index.js --minify --legal-comments=none",
    "lint": "tsc --noEmit",
    "test": "node --test --import tsx test"
  },
  "dependencies": {
    "@actions/core": "^1.11.1",
    "@actions/github": "^6.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.12.0",
    "esbuild": "^0.24.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  },
  "keywords": [
    "github-action",
    "readme",
    "documentation",
    "llm",
    "openai",
    "anthropic",
    "gemini",
    "automation"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mobigaurav/readme-bot.git"
  },
  "engines": {
    "node": ">=20"
  }
}
